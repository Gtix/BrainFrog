generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  AgentSession[]
}

model AgentSession {
  id              String        @id @default(cuid())
  userId          String?
  title           String        @default("New Session")
  platform        String        @default("web")
  externalId      String?
  promptVersionId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User?         @relation(fields: [userId], references: [id])
  messages        ChatMessage[]
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id])
}

model ChatMessage {
  id              String       @id @default(cuid())
  sessionId       String
  role            String
  content         String
  timestamp       DateTime     @default(now())
  rating          Int?
  ratedAt         DateTime?
  promptVersionId String?
  session         AgentSession @relation(fields: [sessionId], references: [id])
}

model MemoryEntry {
  id         String   @id @default(cuid())
  sessionId  String?
  userId     String?
  type       String   @default("working")
  content    String
  accessCount Int     @default(0)
  importance Float    @default(0.5)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PromptVersion {
  id          String   @id @default(cuid())
  label       String
  description String   @default("")
  content     String
  isActive    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  totalUses   Int      @default(0)
  avgRating   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    AgentSession[]
}

model MessagingPlatform {
  id        String   @id @default(cuid())
  platform  String   @unique
  enabled   Boolean  @default(false)
  config    String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityAuditLog {
  id        String   @id @default(cuid())
  event     String
  severity  String   @default("info")
  details   String
  sourceIp  String?
  userId    String?
  createdAt DateTime @default(now())
}
