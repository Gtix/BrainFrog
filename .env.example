# Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="file:./db/dev.db"

# ============================================
# LLM PROVIDERS
# ============================================
# Add API keys for any providers you want to use.
# The gateway tries providers in priority order with automatic failover.
# If no keys are set, the built-in z-ai-web-dev-sdk is used as fallback.

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL=""  # Optional: custom endpoint (Azure, local proxy, etc.)

# Anthropic (Claude Sonnet, Claude Opus, etc.)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
# ANTHROPIC_BASE_URL=""  # Optional: custom endpoint

# Google (Gemini Pro, Gemini Flash, etc.)
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-2.0-flash"
# GOOGLE_BASE_URL=""  # Optional: custom endpoint

# Provider priority (comma-separated, first = highest priority)
# If not set: configured external providers first, z-ai-web-dev-sdk last
# LLM_PRIORITY="openai,anthropic,google,z-ai-web-dev-sdk"

# Default model configuration
DEFAULT_MODEL="gpt-4"
DEFAULT_TEMPERATURE="0.7"
DEFAULT_MAX_TOKENS="4096"

# ============================================
# MESSAGING PLATFORM INTEGRATIONS
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
# TELEGRAM_WEBHOOK_SECRET=""

# Discord Bot
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
# DISCORD_APPLICATION_ID=""

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="brain-frog-verify"

# Optional: Feature Flags
ENABLE_MEMORY="true"
ENABLE_SKILLS="true"
SECURITY_LEVEL="high"
